<Window
    x:Class="PracticeProject.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:PracticeProject.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:materialDesignInternal="http://materialdesigninxaml.net/winfx/xaml/themes-internal"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    Title="MainWindow"
    Width="1200"
    Height="900"
    prism:ViewModelLocator.AutoWireViewModel="True"
    AllowsTransparency="True"
    Style="{StaticResource MaterialDesignWindow}"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <materialDesign:DialogHost Identifier="RootDialog">
        <materialDesign:DrawerHost IsLeftDrawerOpen="{Binding ElementName=MenuToggleButton, Path=IsChecked}">
            <materialDesign:DrawerHost.LeftDrawerContent>
                <!--  左侧抽屉菜单  -->
                <DockPanel MinWidth="220">
                    <DockPanel.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#1B5E20" />
                            <GradientStop Offset="0.5" Color="#4CAF50" />
                            <GradientStop Offset="1" Color="#1B5E20" />
                        </LinearGradientBrush>
                    </DockPanel.Background>
                    <StackPanel Margin="16" DockPanel.Dock="Top">
                        <TextBlock
                            Margin="0,0,0,8"
                            Foreground="White"
                            Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                            Text="练习" />
                        <TextBlock
                            Foreground="White"
                            Opacity="0.6"
                            Style="{StaticResource MaterialDesignBody2TextBlock}"
                            Text="练习" />
                    </StackPanel>

                    <!--  使用 TreeView 实现可展开的父子菜单  -->
                    <TreeView
                        x:Name="MenuTreeView"
                        Margin="0,16,0,16"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding MenuItems}">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="SelectedItemChanged">
                                <i:InvokeCommandAction Command="{Binding NavigateCommand}" CommandParameter="{Binding SelectedItem, ElementName=MenuTreeView}" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                        <TreeView.Resources>
                            <!--  父菜单项样式（有子菜单）  -->
                            <Style x:Key="ParentMenuItemStyle" TargetType="TreeViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="#E5F3FF" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,2" />

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border
                                                    x:Name="Bd"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <ToggleButton
                                                            x:Name="Expander"
                                                            Width="16"
                                                            Height="16"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            ClickMode="Press"
                                                            IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent">
                                                                        <Path
                                                                            x:Name="Arrow"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Data="M 0 0 L 6 5 L 0 10 Z"
                                                                            Fill="#E5F3FF">
                                                                            <Path.RenderTransform>
                                                                                <RotateTransform Angle="0" CenterX="3" CenterY="5" />
                                                                            </Path.RenderTransform>
                                                                        </Path>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Arrow" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <RotateTransform Angle="90" CenterX="3" CenterY="5" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <materialDesign:PackIcon
                                                            Grid.Column="1"
                                                            Width="24"
                                                            Height="24"
                                                            Margin="0,0,16,0"
                                                            Foreground="#E5F3FF"
                                                            Kind="{Binding IconKind}" />
                                                        <TextBlock
                                                            Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Foreground="#E5F3FF"
                                                            Text="{Binding Text}" />
                                                    </Grid>
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost" Margin="20,0,0,0" />
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3B82F6" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1F2937" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <!--  二级菜单：可再展开（如「生产数据查询」下的子项）  -->
                            <Style x:Key="BranchMenuItemStyle" TargetType="TreeViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="#E5F3FF" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border
                                                    x:Name="Bd"
                                                    Margin="0,1"
                                                    Padding="0"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <ToggleButton
                                                            x:Name="Expander"
                                                            Grid.Column="0"
                                                            Width="16"
                                                            Height="16"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            ClickMode="Press"
                                                            IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="ToggleButton">
                                                                    <Border Background="Transparent">
                                                                        <Path
                                                                            x:Name="Arrow"
                                                                            HorizontalAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Data="M 0 0 L 6 5 L 0 10 Z"
                                                                            Fill="#E5F3FF">
                                                                            <Path.RenderTransform>
                                                                                <RotateTransform Angle="0" CenterX="3" CenterY="5" />
                                                                            </Path.RenderTransform>
                                                                        </Path>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsChecked" Value="True">
                                                                            <Setter TargetName="Arrow" Property="RenderTransform">
                                                                                <Setter.Value>
                                                                                    <RotateTransform Angle="90" CenterX="3" CenterY="5" />
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <ContentPresenter
                                                            Grid.Column="1"
                                                            Margin="0,0,8,0"
                                                            VerticalAlignment="Center"
                                                            ContentSource="Header" />
                                                    </Grid>
                                                </Border>
                                                <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0" />
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsExpanded" Value="False">
                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3B82F6" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1F2937" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <!--  三级及以下叶子菜单  -->
                            <Style x:Key="LeafMenuItemStyle" TargetType="TreeViewItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Foreground" Value="#E5F3FF" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TreeViewItem">
                                            <StackPanel>
                                                <Border
                                                    x:Name="Bd"
                                                    Margin="0,1"
                                                    Padding="8,6"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="40" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <materialDesign:PackIcon
                                                            Grid.Column="0"
                                                            Width="18"
                                                            Height="18"
                                                            Margin="0,0,12,0"
                                                            VerticalAlignment="Center"
                                                            Foreground="#E5F3FF"
                                                            Kind="{Binding IconKind}" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Foreground="#E5F3FF"
                                                            Text="{Binding Text}" />
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#3B82F6" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#1F2937" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TreeView.Resources>

                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <StackPanel Margin="0,4" Orientation="Horizontal">
                                    <materialDesign:PackIcon
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,16,0"
                                        VerticalAlignment="Center"
                                        Foreground="#E5F3FF"
                                        Kind="{Binding IconKind}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Foreground="#E5F3FF"
                                        Text="{Binding Text}" />
                                </StackPanel>
                                <HierarchicalDataTemplate.ItemContainerStyle>
                                    <Style BasedOn="{StaticResource BranchMenuItemStyle}" TargetType="TreeViewItem" />
                                </HierarchicalDataTemplate.ItemContainerStyle>
                                <HierarchicalDataTemplate.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <StackPanel Margin="0,2" Orientation="Horizontal">
                                            <materialDesign:PackIcon
                                                Width="18"
                                                Height="18"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center"
                                                Foreground="#E5F3FF"
                                                Kind="{Binding IconKind}" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                Foreground="#E5F3FF"
                                                Text="{Binding Text}" />
                                        </StackPanel>
                                        <HierarchicalDataTemplate.ItemContainerStyle>
                                            <Style BasedOn="{StaticResource LeafMenuItemStyle}" TargetType="TreeViewItem" />
                                        </HierarchicalDataTemplate.ItemContainerStyle>
                                        <HierarchicalDataTemplate.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,2" Orientation="Horizontal">
                                                    <materialDesign:PackIcon
                                                        Width="18"
                                                        Height="18"
                                                        Margin="0,0,12,0"
                                                        VerticalAlignment="Center"
                                                        Foreground="#E5F3FF"
                                                        Kind="{Binding IconKind}" />
                                                    <TextBlock
                                                        VerticalAlignment="Center"
                                                        Foreground="#E5F3FF"
                                                        Text="{Binding Text}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </HierarchicalDataTemplate.ItemTemplate>
                                    </HierarchicalDataTemplate>
                                </HierarchicalDataTemplate.ItemTemplate>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </materialDesign:DrawerHost.LeftDrawerContent>
            <Border Background="Transparent" CornerRadius="10">
                <DockPanel>
                    <!--  顶部工具栏  -->
                    <Border
                        Padding="10"
                        CornerRadius="5,5,5,5"
                        DockPanel.Dock="Top"
                        MouseLeftButtonDown="ColorZone_MouseLeftButtonDown">
                        <Border.Background>
                            <LinearGradientBrush Opacity="0.9" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#0D2E18" />
                                <GradientStop Offset="0.5" Color="#1C5E3A" />
                                <GradientStop Offset="1" Color="#0D2E18" />
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  左侧：菜单按钮和标题  -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ToggleButton
                                    x:Name="MenuToggleButton"
                                    Foreground="White"
                                    IsChecked="False"
                                    Style="{StaticResource MaterialDesignHamburgerToggleButton}" />
                                <TextBlock
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="20"
                                    FontWeight="Medium"
                                    Foreground="White"
                                    Text="浙江云强智能装配有限公司" />
                            </StackPanel>
                            <!--  中间图标  -->
                            <Grid
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Ellipse Width="40" Height="40">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="/Image/Logo.png" Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>


                            <!--  右侧：窗口控制按钮 + 功能按钮  -->
                            <StackPanel
                                Grid.Column="2"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <!--  功能按钮  -->
                                <Button
                                    Margin="4,0"
                                    Foreground="White"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="通知">
                                    <materialDesign:PackIcon Kind="Bell" />
                                </Button>
                                <Button
                                    Margin="4,0"
                                    Foreground="White"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="设置">
                                    <materialDesign:PackIcon Kind="Cog" />
                                </Button>
                                <Button
                                    Margin="4,0"
                                    Foreground="White"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="用户">
                                    <materialDesign:PackIcon Kind="Account" />
                                </Button>

                                <!--  分隔线  -->
                                <Rectangle
                                    Width="1"
                                    Height="24"
                                    Margin="8,0"
                                    Fill="White"
                                    Opacity="0.3" />

                                <!--  窗口控制按钮  -->
                                <Button
                                    x:Name="MinimizeButton"
                                    Margin="4,0"
                                    Click="MinimizeButton_Click"
                                    Foreground="White"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="最小化">
                                    <materialDesign:PackIcon Kind="WindowMinimize" />
                                </Button>
                                <Button
                                    x:Name="MaximizeButton"
                                    Margin="4,0"
                                    Click="MaximizeButton_Click"
                                    Foreground="White"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="最大化">
                                    <materialDesign:PackIcon x:Name="MaximizeIcon" Kind="WindowMaximize" />
                                </Button>
                                <Button
                                    x:Name="CloseButton"
                                    Margin="4,0"
                                    Click="CloseButton_Click"
                                    Foreground="White"
                                    Style="{StaticResource MaterialDesignIconButton}"
                                    ToolTip="关闭">
                                    <materialDesign:PackIcon Kind="Close" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Grid>
                        <!--  主内容区域  -->
                        <Grid
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            Background="Transparent">
                            <ContentControl prism:RegionManager.RegionName="ContentRegion" />
                        </Grid>

                        <!--  右下角抽屉式消息提示组件  -->
                        <materialDesign:DrawerHost
                            Margin="0,0,20,20"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            IsRightDrawerOpen="False"
                            OpenMode="Standard">
                            <materialDesign:DrawerHost.RightDrawerContent>
                                <Border
                                    MinWidth="400"
                                    MinHeight="80"
                                    MaxWidth="600"
                                    MaxHeight="250"
                                    Padding="16"
                                    Background="#1A1A2E"
                                    CornerRadius="12,12,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="20"
                                            Opacity="0.6"
                                            ShadowDepth="0"
                                            Color="Black" />
                                    </Border.Effect>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>

                                        <!--  标题栏  -->
                                        <Grid Grid.Row="0" Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!--  图标和消息类型  -->
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon
                                                    Width="24"
                                                    Height="24"
                                                    VerticalAlignment="Center"
                                                    Foreground="#4CAF50"
                                                    Kind="Information" />
                                                <TextBlock
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    Foreground="White"
                                                    Text="系统消息" />
                                            </StackPanel>

                                            <!--  关闭按钮  -->
                                            <Button
                                                Grid.Column="2"
                                                Width="28"
                                                Height="28"
                                                Foreground="#888888"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="关闭">
                                                <materialDesign:PackIcon
                                                    Width="18"
                                                    Height="18"
                                                    Kind="Close" />
                                            </Button>
                                        </Grid>

                                        <!--  消息内容区域  -->
                                        <Border
                                            Grid.Row="1"
                                            Padding="12,10"
                                            Background="#0F0F1A"
                                            BorderBrush="#2A2A4A"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <ScrollViewer
                                                MaxHeight="120"
                                                HorizontalScrollBarVisibility="Auto"
                                                VerticalScrollBarVisibility="Auto">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontFamily="Microsoft YaHei UI, Consolas"
                                                    FontSize="13"
                                                    Foreground="#E0E0E0"
                                                    Text="暂无消息"
                                                    TextWrapping="Wrap" />
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Border>
                            </materialDesign:DrawerHost.RightDrawerContent>
                        </materialDesign:DrawerHost>
                    </Grid>
                </DockPanel>
            </Border>
        </materialDesign:DrawerHost>
    </materialDesign:DialogHost>
</Window>
