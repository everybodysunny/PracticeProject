<UserControl
    x:Class="PracticeProject.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PracticeProject.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Blue"
                    SecondaryColor="Pink" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!--  设备卡片样式  -->
            <Style x:Key="DeviceCardBorder" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,12,12" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="8"
                            Opacity="0.1"
                            ShadowDepth="2"
                            Color="Black" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  统计卡片样式  -->
            <Style x:Key="StatCard" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="20,16" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect
                            BlurRadius="6"
                            Opacity="0.08"
                            ShadowDepth="1"
                            Color="Black" />
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid
        Margin="16"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.FontSize="14"
        TextElement.FontWeight="Regular"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部欢迎栏  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,16"
            Padding="24,18"
            Background="#1976D2"
            CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="12"
                    Opacity="0.2"
                    ShadowDepth="3"
                    Color="#1976D2" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="监控系统主页" />
                    <TextBlock
                        Margin="0,6,0,0"
                        FontSize="13"
                        Foreground="White"
                        Opacity="0.85"
                        Text="实时显示所有 PLC 设备的运行状态和数据" />
                </StackPanel>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="18"
                        Height="18"
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Foreground="White"
                        Opacity="0.8"
                        Kind="Clock" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13"
                        Foreground="White"
                        Opacity="0.9">
                        <Run Text="最后更新: " />
                        <Run FontWeight="Medium" Text="{Binding LastUpdateText, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!--  统计概览  -->
        <UniformGrid
            Grid.Row="1"
            Margin="0,0,0,16"
            Columns="4"
            Rows="1">

            <!--  设备总数  -->
            <Border Style="{StaticResource StatCard}" Margin="0,0,8,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            Foreground="#888"
                            Text="设备总数" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#1976D2"
                            Text="{Binding TotalDevices}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="#666"
                            Text="{Binding OverallStatusText}" />
                    </StackPanel>
                    <materialDesign:PackIcon
                        Grid.Column="1"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Center"
                        Foreground="#1976D2"
                        Opacity="0.3"
                        Kind="Server" />
                </Grid>
            </Border>

            <!--  在线设备  -->
            <Border Style="{StaticResource StatCard}" Margin="4,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            Foreground="#888"
                            Text="在线设备" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#4CAF50"
                            Text="{Binding OnlineDevices}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="#666"
                            Text="通信正常" />
                    </StackPanel>
                    <materialDesign:PackIcon
                        Grid.Column="1"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Center"
                        Foreground="#4CAF50"
                        Opacity="0.3"
                        Kind="CheckCircle" />
                </Grid>
            </Border>

            <!--  离线设备  -->
            <Border Style="{StaticResource StatCard}" Margin="4,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            Foreground="#888"
                            Text="离线设备" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#F44336"
                            Text="{Binding OfflineDevices}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="#666"
                            Text="需要检查" />
                    </StackPanel>
                    <materialDesign:PackIcon
                        Grid.Column="1"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Center"
                        Foreground="#F44336"
                        Opacity="0.3"
                        Kind="AlertCircle" />
                </Grid>
            </Border>

            <!--  系统健康度  -->
            <Border Style="{StaticResource StatCard}" Margin="8,0,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            Foreground="#888"
                            Text="系统健康度" />
                        <TextBlock
                            Margin="0,6,0,0"
                            FontSize="28"
                            FontWeight="Bold"
                            Foreground="#FF9800"
                            Text="{Binding SystemHealthText}" />
                        <TextBlock
                            Margin="0,4,0,0"
                            FontSize="12"
                            Foreground="#666">
                            <Run Text="读取: " />
                            <Run Text="{Binding TotalReadsText, Mode=OneWay}" />
                            <Run Text=" 错误: " />
                            <Run Text="{Binding TotalErrorsText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                    <materialDesign:PackIcon
                        Grid.Column="1"
                        Width="36"
                        Height="36"
                        VerticalAlignment="Center"
                        Foreground="#FF9800"
                        Opacity="0.3"
                        Kind="ChartLine" />
                </Grid>
            </Border>
        </UniformGrid>

        <!--  主体：左侧设备卡片 + 右侧活动  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <!--  设备数据卡片  -->
            <materialDesign:Card Grid.Column="0" Padding="16">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="#1976D2"
                                Kind="ChartBox" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Medium"
                                Text="设备实时数据" />
                        </StackPanel>
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="#666"
                            Text="自动刷新" />
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DeviceCards}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Width="320"
                                        Margin="0,0,12,12"
                                        Padding="16"
                                        Background="White"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                        <StackPanel>
                                            <!--  设备头部  -->
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="16"
                                                        FontWeight="Bold"
                                                        Text="{Binding DeviceName}" />
                                                    <TextBlock
                                                        Margin="0,2,0,0"
                                                        FontSize="12"
                                                        Foreground="#666">
                                                        <Run Text="{Binding IpAddress, Mode=OneWay}" />
                                                        <Run Text=":" />
                                                        <Run Text="{Binding Port, Mode=OneWay}" />
                                                    </TextBlock>
                                                </StackPanel>

                                                <Border
                                                    Grid.Column="1"
                                                    Padding="8,4"
                                                    VerticalAlignment="Center"
                                                    Background="{Binding StatusBrush}"
                                                    CornerRadius="10">
                                                    <TextBlock
                                                        FontSize="12"
                                                        FontWeight="Medium"
                                                        Foreground="White"
                                                        Text="{Binding StatusText}" />
                                                </Border>
                                            </Grid>

                                            <!--  设备信息  -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="#999"
                                                        Text="轮询间隔" />
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontWeight="Medium"
                                                        Text="{Binding PollingIntervalText}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock
                                                        FontSize="11"
                                                        Foreground="#999"
                                                        Text="寄存器数量" />
                                                    <TextBlock
                                                        FontSize="13"
                                                        FontWeight="Medium">
                                                        <Run Text="{Binding RegisterCount, Mode=OneWay}" />
                                                        <Run Text="个" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>

                                            <!--  数据  -->
                                            <Border
                                                Padding="10,8"
                                                Background="#F5F5F5"
                                                CornerRadius="6">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock
                                                        Grid.Row="0"
                                                        FontSize="11"
                                                        Foreground="#999"
                                                        Text="最新数据" />
                                                    <ItemsControl
                                                        Grid.Row="1"
                                                        Margin="0,4,0,0"
                                                        ItemsSource="{Binding RegisterValues}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,2">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="80" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock
                                                                        FontSize="12"
                                                                        Foreground="#555"
                                                                        Text="{Binding Name}" />
                                                                    <TextBlock
                                                                        Grid.Column="1"
                                                                        FontSize="12"
                                                                        FontWeight="Medium"
                                                                        Text="{Binding Value}" />
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>

                                            <!--  最后更新  -->
                                            <TextBlock
                                                Margin="0,8,0,0"
                                                FontSize="11"
                                                Foreground="#999">
                                                <Run Text="最后更新: " />
                                                <Run Text="{Binding LastUpdateText, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </materialDesign:Card>

            <!--  活动记录  -->
            <materialDesign:Card Grid.Column="2" Padding="16">
                <DockPanel>
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon
                                Width="20"
                                Height="20"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Foreground="#FF9800"
                                Kind="History" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="16"
                                FontWeight="Medium"
                                Text="最近活动" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentActivities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="10,8"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse
                                                Grid.Column="0"
                                                Width="8"
                                                Height="8"
                                                Margin="0,4,8,0"
                                                VerticalAlignment="Top"
                                                Fill="{Binding TypeBrush}" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Text="{Binding Type}" />
                                                <TextBlock
                                                    Margin="0,2,0,0"
                                                    FontSize="11"
                                                    Foreground="#666"
                                                    Text="{Binding Message}"
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="2"
                                                Margin="8,0,0,0"
                                                VerticalAlignment="Top"
                                                FontSize="11"
                                                Foreground="#999"
                                                Text="{Binding TimestampText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>
