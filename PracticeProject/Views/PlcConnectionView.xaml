<UserControl
    x:Class="PracticeProject.Views.PlcConnectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PracticeProject.Views"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:prism="http://prismlibrary.com/"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    prism:ViewModelLocator.AutoWireViewModel="True"
    mc:Ignorable="d">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme
                    BaseTheme="Light"
                    PrimaryColor="Blue"
                    SecondaryColor="Pink" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

            <!--
                修复 MaterialDesign 默认 DataGrid 样式的 FindAncestor 绑定问题。
                默认样式用 RelativeSource FindAncestor 找 DataGrid/DataGridRow 的属性，
                在某些容器（如 materialDesign:Card）下找不到祖先，导致绑定失败。
                这里用显式值覆盖默认样式。
            -->
            <Style x:Key="FixedDataGridCellStyle" TargetType="DataGridCell">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="Foreground" Value="#333333" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#E3F2FD" />
                        <Setter Property="Foreground" Value="#0D47A1" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="FixedDataGridRowHeaderStyle" TargetType="DataGridRowHeader">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="LightGray" />
                <Setter Property="BorderThickness" Value="0,0,1,0" />
                <Setter Property="Padding" Value="4,0" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid
        Margin="16"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}"
        TextElement.FontSize="14"
        TextElement.FontWeight="Regular"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  顶部状态行  -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,12"
            Padding="20,16"
            Background="White"
            CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <materialDesign:PackIcon
                        Width="28"
                        Height="28"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        Foreground="#1976D2"
                        Kind="LanConnect" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="20"
                        FontWeight="Bold"
                        Text="PLC 通讯设置" />
                </StackPanel>

                <!--  统计信息  -->
                <StackPanel
                    Grid.Column="1"
                    Margin="0,0,24,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <StackPanel Margin="12,0" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Foreground="#4CAF50"
                            Kind="CheckCircle" />
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="成功: " />
                            <Run FontWeight="Bold" Text="{Binding SuccessCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Margin="12,0" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Foreground="#F44336"
                            Kind="AlertCircle" />
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="失败: " />
                            <Run FontWeight="Bold" Text="{Binding ErrorCount, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Margin="12,0" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Foreground="#2196F3"
                            Kind="Clock" />
                        <TextBlock VerticalAlignment="Center">
                            <Run Text="最后更新: " />
                            <Run FontWeight="Bold" Text="{Binding LastUpdateText, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!--  状态指示  -->
                <Border
                    Grid.Column="2"
                    Padding="12,6"
                    Background="{DynamicResource MaterialDesignCardBackground}"
                    CornerRadius="12">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            Width="10"
                            Height="10"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#9E9E9E" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="#4CAF50" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontWeight="Medium"
                            Text="{Binding StatusText}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!--  主体内容  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  左侧：控制面板  -->
            <StackPanel Grid.Column="0">

                <!--  设备选择  -->
                <materialDesign:Card Margin="0,0,0,12" Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="15"
                            FontWeight="Medium"
                            Text="设备选择" />

                        <ComboBox
                            Margin="0,4,0,8"
                            materialDesign:HintAssist.Hint="选择设备"
                            DisplayMemberPath="."
                            ItemsSource="{Binding AvailableDevices}"
                            SelectedItem="{Binding SelectedDevice}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button
                                Grid.Column="0"
                                Command="{Binding StartCommand}"
                                Content="启动"
                                Style="{StaticResource MaterialDesignRaisedButton}" />
                            <Button
                                Grid.Column="2"
                                Command="{Binding StopCommand}"
                                Content="停止"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                            <Button
                                Grid.Column="4"
                                Command="{Binding RefreshCommand}"
                                Content="刷新"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!--  写入测试  -->
                <materialDesign:Card Padding="16">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,12"
                            FontSize="15"
                            FontWeight="Medium"
                            Text="手动写入测试" />

                        <TextBox
                            Margin="0,4,0,8"
                            materialDesign:HintAssist.Hint="写入地址 (0-65535)"
                            Text="{Binding WriteAddress, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox
                            Margin="0,4,0,12"
                            materialDesign:HintAssist.Hint="值 (0-65535)"
                            Text="{Binding WriteValue, UpdateSourceTrigger=PropertyChanged}" />

                        <Button
                            Command="{Binding WriteCommand}"
                            Content="写入寄存器"
                            Style="{StaticResource MaterialDesignRaisedButton}" />
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>

            <!--  右侧：数据 + 日志  -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <!--  寄存器数据表格  -->
                <materialDesign:Card Grid.Row="0" Padding="16">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                FontSize="15"
                                FontWeight="Medium"
                                Text="实时寄存器数据" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="#666"
                                Text="{Binding LastUpdateText, StringFormat='最后更新: {0}'}" />
                        </Grid>

                        <DataGrid
                            AutoGenerateColumns="False"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CellStyle="{StaticResource FixedDataGridCellStyle}"
                            HeadersVisibility="Column"
                            IsReadOnly="True"
                            ItemsSource="{Binding RegisterItems}"
                            RowHeaderStyle="{StaticResource FixedDataGridRowHeaderStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="寄存器名称" />
                                <DataGridTextColumn
                                    Width="100"
                                    Binding="{Binding StartAddress}"
                                    Header="起始地址" />
                                <DataGridTextColumn
                                    Width="80"
                                    Binding="{Binding Count}"
                                    Header="数量" />
                                <DataGridTextColumn
                                    Width="150"
                                    Binding="{Binding DisplayValue}"
                                    Header="十进制值" />
                                <DataGridTextColumn
                                    Width="200"
                                    Binding="{Binding HexValue}"
                                    Header="十六进制" />
                                <DataGridTextColumn
                                    Width="120"
                                    Binding="{Binding LastUpdateText, Mode=OneWay}"
                                    Header="更新时间" />
                                <DataGridTemplateColumn Width="100" Header="状态">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border
                                                Padding="8,2"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#E8F5E9" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                <Setter Property="Background" Value="#FFEBEE" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    FontSize="12"
                                                    FontWeight="Medium"
                                                    Foreground="#2E7D32"
                                                    Text="{Binding StatusText}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#2E7D32" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSuccess}" Value="False">
                                                                    <Setter Property="Foreground" Value="#C62828" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </materialDesign:Card>

                <!--  通讯日志  -->
                <materialDesign:Card Grid.Row="2" Padding="0">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="16,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Foreground="#FF9800"
                                    Kind="MessageText" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="Medium"
                                    Text="通讯日志" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                Command="{Binding ClearLogCommand}"
                                Content="清空"
                                Style="{StaticResource MaterialDesignOutlinedButton}" />
                        </Grid>

                        <Border
                            Margin="16,0,16,16"
                            Background="#263238"
                            CornerRadius="6">
                            <ListBox
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="Consolas"
                                FontSize="13"
                                Foreground="White"
                                ItemsSource="{Binding LogMessages}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="12,3" />
                                        <Setter Property="Margin" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </DockPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
